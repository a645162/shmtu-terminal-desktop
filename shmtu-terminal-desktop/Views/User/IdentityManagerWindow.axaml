<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                xmlns:appControls="using:shmtu.terminal.desktop.Controls"
        xmlns:vm="using:shmtu.terminal.desktop.ViewModels.User"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="550"
        x:Class="shmtu.terminal.desktop.Views.User.IdentityManagerWindow"
        x:DataType="vm:IdentityManagerViewModel"
        Title="身份与账号管理"
        Width="800" Height="550"
        WindowStartupLocation="CenterOwner"
        MinWidth="700" MinHeight="450"
        TransparencyLevelHint="AcrylicBlur">

    <Grid ColumnDefinitions="220,*">

        <!-- Left: Identity List -->
        <Border Grid.Column="0"
                Background="{DynamicResource MaterialDesignToolBarBackground}"
                Padding="12,16">
            <DockPanel>

                <!-- Identity List Actions -->
                <StackPanel DockPanel.Dock="Bottom"
                            Orientation="Horizontal"
                            Spacing="4"
                            HorizontalAlignment="Center"
                            Margin="0,8,0,0">
                    <Button Content="+"
                            Command="{Binding AddIdentityCommand}"
                            ToolTip.Tip="新建身份"
                            Width="36" Height="36" />
                    <Button Content="✎"
                            Command="{Binding EditIdentityCommand}"
                            ToolTip.Tip="编辑身份"
                            Width="36" Height="36" />
                    <Button Content="-"
                            Command="{Binding DeleteIdentityCommand}"
                            ToolTip.Tip="删除身份"
                            Width="36" Height="36" />
                </StackPanel>

                <!-- Identity Label -->
                <TextBlock DockPanel.Dock="Top"
                           Text="身份列表"
                           FontSize="14" FontWeight="SemiBold"
                           Margin="0,0,0,8" />

                <!-- Identity ListBox -->
                <ListBox Name="IdentityListBox"
                         ItemsSource="{Binding Identities}"
                         SelectedItem="{Binding SelectedIdentity}">
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="编辑"
                                      Command="{Binding EditIdentityCommand}" />
                            <MenuItem Header="删除"
                                      Command="{Binding DeleteIdentityCommand}" />
                            <Separator />
                            <MenuItem Header="设为默认"
                                      Command="{Binding SetDefaultIdentityCommand}" />
                        </ContextMenu>
                    </ListBox.ContextMenu>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,4">
                                <TextBlock Text="{Binding Name}"
                                           FontSize="14" FontWeight="Medium" />
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock FontSize="11"
                                               Foreground="{DynamicResource MaterialDesignBodyLight}">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0}个账号">
                                                <Binding Path="AccountCount" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                    <TextBlock Text="默认"
                                               FontSize="10"
                                               Foreground="#1976D2"
                                               IsVisible="{Binding IsDefault}" />
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </DockPanel>
        </Border>

        <!-- Right: Account List -->
        <Grid Grid.Column="1" Margin="16">

            <DockPanel>

                <!-- Add Account Button -->
                <Button DockPanel.Dock="Top"
                        Content="+ 添加账号"
                        Command="{Binding AddAccountCommand}"
                        HorizontalAlignment="Left"
                        Classes="Flat"
                        Margin="0,0,0,8"
                        IsEnabled="{Binding HasSelectedIdentity}" />

                <!-- Selected Identity Header -->
                <TextBlock DockPanel.Dock="Top"
                           Margin="0,0,0,8"
                           IsVisible="{Binding HasSelectedIdentity}">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0} 的账号列表">
                            <Binding Path="SelectedIdentityName" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>

                <!-- Empty hint when no identity selected -->
                <TextBlock DockPanel.Dock="Top"
                           Text="请先在左侧选择一个身份"
                           FontSize="14"
                           Foreground="{DynamicResource MaterialDesignBodyLight}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           IsVisible="{Binding !HasSelectedIdentity}" />

                <!-- Account Cards -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Accounts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <appControls:Card Margin="0,0,0,8" Padding="12">
                                    <appControls:Card.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="编辑"
                                                      Command="{Binding $parent[Window].DataContext.EditAccountCommand}"
                                                      CommandParameter="{Binding}" />
                                            <MenuItem Header="删除"
                                                      Command="{Binding $parent[Window].DataContext.DeleteAccountCommand}"
                                                      CommandParameter="{Binding}" />
                                        </ContextMenu>
                                    </appControls:Card.ContextMenu>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Spacing="4">
                                            <TextBlock FontSize="14" FontWeight="Medium">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}学号: {0}">
                                                        <Binding Path="AccountId" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                            <TextBlock FontSize="12"
                                                       Foreground="{DynamicResource MaterialDesignBodyLight}">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}名称: {0}">
                                                        <Binding Path="AccountName" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock FontSize="11"
                                                           Foreground="#4CAF50"
                                                           Text="已启用"
                                                           IsVisible="{Binding Enable}" />
                                                <TextBlock FontSize="11"
                                                           Foreground="#F44336"
                                                           Text="已禁用"
                                                           IsVisible="{Binding !Enable}" />
                                            </StackPanel>
                                            <TextBlock FontSize="11"
                                                       Foreground="{DynamicResource MaterialDesignBodyLight}">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}最后同步: {0}">
                                                        <Binding Path="LastUpdateTime" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Spacing="4">
                                            <ToggleButton IsChecked="{Binding Enable}"
                                                          Content="启用" />
                                            <Button Content="编辑"
                                                    Command="{Binding $parent[Window].DataContext.EditAccountCommand}"
                                                    CommandParameter="{Binding}"
                                                    FontSize="12"
                                                    Classes="Flat" />
                                            <Button Content="删除"
                                                    Command="{Binding $parent[Window].DataContext.DeleteAccountCommand}"
                                                    CommandParameter="{Binding}"
                                                    FontSize="12"
                                                    Classes="Flat" />
                                        </StackPanel>
                                    </Grid>
                                </appControls:Card>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>

        </Grid>
    </Grid>

</Window>
