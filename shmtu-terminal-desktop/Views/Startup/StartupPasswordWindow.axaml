<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:material="using:Material.Styles"
        mc:Ignorable="d" d:DesignWidth="340" d:DesignHeight="220"
        x:Class="shmtu.terminal.desktop.Views.Startup.StartupPasswordWindow"
        Title="请输入密码"
        Width="340" Height="220"
        WindowStartupLocation="CenterScreen"
        SizeToContent="Manual"
        CanResize="False"
        TransparencyLevelHint="AcrylicBlur"
        Background="{DynamicResource MaterialDesignBackground}">

    <StackPanel Margin="32,24" Spacing="16"
                HorizontalAlignment="Center">

        <!-- Lock Icon & Info -->
        <TextBlock Text="应用已设置密码保护"
                   FontSize="14"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,8" />

        <!-- Password Input -->
        <StackPanel Spacing="8" HorizontalAlignment="Center">
            <TextBlock Text="密码:"
                       FontSize="12" />
            <TextBox PasswordChar="*"
                     Text="{Binding Password}"
                     Width="240"
                     HorizontalAlignment="Center"
                     KeyDown="PasswordBox_KeyDown" />
        </StackPanel>

        <!-- Error Message -->
        <TextBlock Text="{Binding ErrorMessage}"
                   FontSize="12"
                   Foreground="#F44336"
                   HorizontalAlignment="Center"
                   IsVisible="{Binding HasError}" />

        <!-- Confirm Button -->
        <Button Content="确认"
                Command="{Binding ConfirmCommand}"
                Classes="Primary"
                HorizontalAlignment="Center"
                Width="120" />

    </StackPanel>

</Window>
