<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:shmtu.terminal.desktop.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:material="using:Material.Styles"
        xmlns:tabViews="using:shmtu.terminal.desktop.Views.MainWindowTab"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="650"
        x:Class="shmtu.terminal.desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="海大终端"
        Width="1000" Height="650"
        MinWidth="800" MinHeight="500"
        TransparencyLevelHint="AcrylicBlur"
        Background="{DynamicResource MaterialDesignBackground}">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.Styles>
        <!-- Tab style overrides for Material look -->
        <Style Selector="TabItem">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Padding" Value="24,12" />
        </Style>
    </Window.Styles>

    <DockPanel>
        <!-- Status Bar at Bottom -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource MaterialDesignToolBarBackground}"
                Padding="16,6">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                <TextBlock Grid.Column="0"
                           Text="{Binding CurrentIdentityName}"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{DynamicResource MaterialDesignBodyLight}" />
                <TextBlock Grid.Column="2"
                           Text="{Binding SyncStatus}"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{DynamicResource MaterialDesignBodyLight}"
                           Margin="16,0,0,0" />
                <TextBlock Grid.Column="3"
                           Text="{Binding LastSyncTime}"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{DynamicResource MaterialDesignBodyLight}"
                           Margin="16,0,0,0" />
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid>
            <TabControl Name="MainTabControl"
                        SelectedIndex="{Binding SelectedTabIndex}">

                <!-- Home Tab -->
                <TabItem Header="首页">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <tabViews:HomeTabView DataContext="{Binding HomeViewModel}" />
                    </ScrollViewer>
                </TabItem>

                <!-- Bill Tab -->
                <TabItem Header="账单">
                    <tabViews:BillTabView DataContext="{Binding BillViewModel}" />
                </TabItem>

                <!-- Features Tab -->
                <TabItem Header="功能大全">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <tabViews:FeaturesTabView DataContext="{Binding FeaturesViewModel}" />
                    </ScrollViewer>
                </TabItem>

            </TabControl>
        </Grid>
    </DockPanel>

</Window>
