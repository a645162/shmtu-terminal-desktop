<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                xmlns:appControls="using:shmtu.terminal.desktop.Controls"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="600"
        x:Class="shmtu.terminal.desktop.Views.Program.CaptchaTestWindow"
        Title="验证码测试"
        Width="500" Height="600"
        WindowStartupLocation="CenterOwner"
        MinWidth="400" MinHeight="500"
        TransparencyLevelHint="AcrylicBlur">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  Padding="24,16">
        <StackPanel Spacing="16">

            <!-- Captcha Mode Selection -->
            <DockPanel>
                <TextBlock Text="识别模式:"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Left" />
                <ComboBox ItemsSource="{Binding CaptchaModes}"
                          SelectedItem="{Binding SelectedCaptchaMode}"
                          HorizontalAlignment="Right"
                          MinWidth="150" />
            </DockPanel>

            <!-- Captcha Image Display -->
            <appControls:Card Padding="16" HorizontalAlignment="Center">
                <StackPanel Spacing="8" HorizontalAlignment="Center">
                    <Border Width="200" Height="66"
                            Background="#F5F5F5"
                            CornerRadius="4"
                            HorizontalAlignment="Center">
                        <Panel>
                            <Image Source="{Binding CaptchaImage}"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                            <TextBlock Text="验证码图片"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource MaterialDesignBodyLight}"
                                       IsVisible="{Binding !HasCaptchaImage}" />
                        </Panel>
                    </Border>
                    <Button Content="刷新验证码"
                            Command="{Binding RefreshCaptchaCommand}"
                            HorizontalAlignment="Center"
                            Classes="Flat" />
                </StackPanel>
            </appControls:Card>

            <!-- Recognition Result -->
            <appControls:Card Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="识别结果"
                               FontSize="14" FontWeight="SemiBold" />
                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto"
                          RowSpacing="4">
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="结果: "
                                   FontSize="13" />
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="{Binding RecognizeResult}"
                                   FontSize="13" FontWeight="Medium" />

                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="耗时: "
                                   FontSize="12"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}" />
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{Binding RecognizeTime}"
                                   FontSize="12"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}" />

                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="类型: "
                                   FontSize="12"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}" />
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   Text="{Binding RecognizeType}"
                                   FontSize="12"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}" />
                    </Grid>
                </StackPanel>
            </appControls:Card>

            <!-- Test Buttons -->
            <StackPanel Orientation="Horizontal"
                        Spacing="8"
                        HorizontalAlignment="Center">
                <Button Content="测试识别"
                        Command="{Binding TestRecognizeCommand}"
                        Classes="Primary" />
                <Button Content="批量测试(10次)"
                        Command="{Binding BatchTestCommand}" />
            </StackPanel>

            <!-- Progress for batch test -->
            <ProgressBar IsVisible="{Binding IsBatchTesting}"
                         Value="{Binding BatchProgress}"
                         Maximum="10" />

            <!-- Test History -->
            <appControls:Card Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="测试历史"
                               FontSize="14" FontWeight="SemiBold" />

                    <DataGrid ItemsSource="{Binding TestHistory}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Height="180">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#"
                                                Binding="{Binding TestNumber}"
                                                Width="40" />
                            <DataGridTextColumn Header="结果"
                                                Binding="{Binding ResultText}"
                                                Width="*" />
                            <DataGridTextColumn Header="耗时"
                                                Binding="{Binding ElapsedTime}"
                                                Width="Auto" />
                            <DataGridTextColumn Header="模式"
                                                Binding="{Binding Mode}"
                                                Width="Auto" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Button Content="清空历史"
                            Command="{Binding ClearHistoryCommand}"
                            Classes="Flat"
                            FontSize="12"
                            HorizontalAlignment="Right" />
                </StackPanel>
            </appControls:Card>

        </StackPanel>
    </ScrollViewer>

</Window>
