<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                xmlns:appControls="using:shmtu.terminal.desktop.Controls"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="550"
        x:Class="shmtu.terminal.desktop.Views.Program.DataTransferWindow"
        Title="数据管理"
        Width="600" Height="550"
        WindowStartupLocation="CenterOwner"
        MinWidth="500" MinHeight="450"
        TransparencyLevelHint="AcrylicBlur">

    <DockPanel>

        <!-- Tab Header -->
        <TabControl Name="DataTabControl"
                    SelectedIndex="{Binding SelectedTabIndex}"
                    DockPanel.Dock="Top">

            <TabItem Header="导出" />
            <TabItem Header="导入" />
            <TabItem Header="快照" />

        </TabControl>

        <!-- Content Area -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Padding="24,16">
            <StackPanel>
            <!-- Export Panel -->
            <Panel IsVisible="{Binding IsExportTab}">
                <StackPanel Spacing="16">
                    <TextBlock Text="数据导出" FontSize="18" FontWeight="Bold" />

                    <appControls:Card Padding="16">
                        <StackPanel Spacing="12">
                            <DockPanel>
                                <TextBlock Text="数据范围"
                                           VerticalAlignment="Center"
                                           DockPanel.Dock="Left" />
                                <ComboBox ItemsSource="{Binding ExportDataScopes}"
                                          SelectedItem="{Binding SelectedExportScope}"
                                          HorizontalAlignment="Right"
                                          MinWidth="180" />
                            </DockPanel>

                            <DockPanel>
                                <TextBlock Text="身份选择"
                                           VerticalAlignment="Center"
                                           DockPanel.Dock="Left" />
                                <ComboBox ItemsSource="{Binding IdentityList}"
                                          SelectedItem="{Binding SelectedExportIdentity}"
                                          HorizontalAlignment="Right"
                                          MinWidth="180" />
                            </DockPanel>

                            <DockPanel>
                                <TextBlock Text="数据类型"
                                           VerticalAlignment="Center"
                                           DockPanel.Dock="Left" />
                                <ComboBox ItemsSource="{Binding SourceTypes}"
                                          SelectedItem="{Binding SelectedSourceType}"
                                          HorizontalAlignment="Right"
                                          MinWidth="180" />
                            </DockPanel>

                            <TextBlock Text="导出格式"
                                       FontSize="12"
                                       Foreground="{DynamicResource MaterialDesignBodyLight}" />
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <RadioButton Content="CSV"
                                             IsChecked="{Binding IsCsvFormat}"
                                             GroupName="ExportFormat" />
                                <RadioButton Content="JSON"
                                             IsChecked="{Binding IsJsonFormat}"
                                             GroupName="ExportFormat" />
                                <RadioButton Content="钱迹格式"
                                             IsChecked="{Binding IsQianjiFormat}"
                                             GroupName="ExportFormat" />
                            </StackPanel>

                            <TextBlock Text="保存路径"
                                       FontSize="12"
                                       Foreground="{DynamicResource MaterialDesignBodyLight}" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBox Text="{Binding ExportPath}"
                                         Width="350" />
                                <Button Content="浏览"
                                        Command="{Binding BrowseExportPathCommand}"
                                        Classes="Flat" />
                            </StackPanel>

                            <Button Content="开始导出"
                                    Command="{Binding StartExportCommand}"
                                    Classes="Primary"
                                    HorizontalAlignment="Left" />

                            <!-- Progress -->
                            <ProgressBar IsVisible="{Binding IsExporting}"
                                         IsIndeterminate="{Binding IsExportIndeterminate}"
                                         Value="{Binding ExportProgress}"
                                         Maximum="100" />
                            <TextBlock Text="{Binding ExportStatus}"
                                       FontSize="12"
                                       Foreground="{DynamicResource MaterialDesignBodyLight}"
                                       IsVisible="{Binding IsExporting}" />
                        </StackPanel>
                    </appControls:Card>
                </StackPanel>
            </Panel>

            <!-- Import Panel -->
            <Panel IsVisible="{Binding IsImportTab}">
                <StackPanel Spacing="16">
                    <TextBlock Text="数据导入" FontSize="18" FontWeight="Bold" />

                    <appControls:Card Padding="16">
                        <StackPanel Spacing="12">
                            <TextBlock Text="导入文件"
                                       FontSize="12"
                                       Foreground="{DynamicResource MaterialDesignBodyLight}" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBox Text="{Binding ImportFilePath}"
                                         PlaceholderText="选择JSON文件"
                                         Width="350" />
                                <Button Content="浏览"
                                        Command="{Binding BrowseImportFileCommand}"
                                        Classes="Flat" />
                            </StackPanel>

                            <DockPanel>
                                <TextBlock Text="导入到身份"
                                           VerticalAlignment="Center"
                                           DockPanel.Dock="Left" />
                                <ComboBox ItemsSource="{Binding IdentityList}"
                                          SelectedItem="{Binding SelectedImportIdentity}"
                                          HorizontalAlignment="Right"
                                          MinWidth="180" />
                            </DockPanel>

                            <!-- Import Preview -->
                            <Panel IsVisible="{Binding HasImportPreview}">
                                <appControls:Card Padding="12" Margin="0,4,0,0">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="导入预览"
                                                   FontSize="12" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding ImportPreviewInfo}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource MaterialDesignBodyLight}" />
                                    </StackPanel>
                                </appControls:Card>
                            </Panel>

                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="预览数据"
                                        Command="{Binding PreviewImportCommand}" />
                                <Button Content="开始导入"
                                        Command="{Binding StartImportCommand}"
                                        Classes="Primary" />
                            </StackPanel>
                        </StackPanel>
                    </appControls:Card>
                </StackPanel>
            </Panel>

            <!-- Snapshot Panel -->
            <Panel IsVisible="{Binding IsSnapshotTab}">
                <StackPanel Spacing="16">
                    <TextBlock Text="快照管理" FontSize="18" FontWeight="Bold" />

                    <appControls:Card Padding="16">
                        <StackPanel Spacing="12">
                            <DockPanel>
                                <StackPanel Orientation="Horizontal"
                                            Spacing="8"
                                            DockPanel.Dock="Left">
                                    <Button Content="创建快照"
                                            Command="{Binding CreateSnapshotCommand}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            Spacing="8">
                                    <TextBlock Text="自动保留:"
                                               VerticalAlignment="Center"
                                               FontSize="12" />
                                    <NumericUpDown Value="{Binding SnapshotKeepCount}"
                                                   Minimum="1" Maximum="100"
                                                   Width="80" />
                                    <TextBlock Text="个"
                                               VerticalAlignment="Center"
                                               FontSize="12" />
                                </StackPanel>
                            </DockPanel>

                            <!-- Snapshot List -->
                            <DataGrid ItemsSource="{Binding Snapshots}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      Height="250">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="快照时间"
                                                        Binding="{Binding SnapshotTime}"
                                                        Width="*" />
                                    <DataGridTextColumn Header="大小"
                                                        Binding="{Binding SizeText}"
                                                        Width="Auto" />
                                    <DataGridTemplateColumn Header="操作" Width="Auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <Button Content="恢复"
                                                            Classes="Flat"
                                                            FontSize="12"
                                                            Command="{Binding RestoreCommand}" />
                                                    <Button Content="删除"
                                                            Classes="Flat"
                                                            FontSize="12"
                                                            Command="{Binding DeleteCommand}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </appControls:Card>
                </StackPanel>
            </Panel>
            </StackPanel>

        </ScrollViewer>
    </DockPanel>

</Window>
