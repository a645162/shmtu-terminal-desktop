<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:material="using:Material.Styles"
             xmlns:billFilter="using:shmtu.terminal.desktop.Views.Component.Bill"
             mc:Ignorable="d" d:DesignWidth="960" d:DesignHeight="560"
             x:Class="shmtu.terminal.desktop.Views.MainWindowTab.BillTabView">

    <DockPanel Margin="16,8">

        <!-- Filter Bar at Top -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource MaterialDesignCardBackground}"
                CornerRadius="8"
                Padding="16,12"
                Margin="0,0,0,8"
                BoxShadow="0 1 3 0 #1F000000">
            <billFilter:BillFilterUserControl DataContext="{Binding FilterViewModel}" />
        </Border>

        <!-- Pagination at Bottom -->
        <Border DockPanel.Dock="Bottom"
                Padding="16,8"
                Margin="0,8,0,0">
            <DockPanel>
                <TextBlock Text="{Binding PaginationInfo}"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{DynamicResource MaterialDesignBodyLight}" />
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="4">
                    <Button Content="首页"
                            Command="{Binding FirstPageCommand}"
                            Classes="Flat" FontSize="12" />
                    <Button Content="上一页"
                            Command="{Binding PrevPageCommand}"
                            Classes="Flat" FontSize="12" />
                    <Button Content="下一页"
                            Command="{Binding NextPageCommand}"
                            Classes="Flat" FontSize="12" />
                    <Button Content="末页"
                            Command="{Binding LastPageCommand}"
                            Classes="Flat" FontSize="12" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- DataGrid -->
        <DataGrid Name="BillDataGrid"
                  ItemsSource="{Binding BillItems}"
                  SelectedItem="{Binding SelectedBillItem}"
                  AutoGenerateColumns="False"
                  CanUserSortColumns="True"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="0"
                  Background="{DynamicResource MaterialDesignCardBackground}"
                  RowBackground="Transparent">

            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="复制交易号"
                              Command="{Binding CopyNumberCommand}" />
                    <MenuItem Header="复制金额"
                              Command="{Binding CopyMoneyCommand}" />
                    <Separator />
                    <MenuItem Header="查看详情"
                              Command="{Binding ViewDetailCommand}" />
                    <MenuItem Header="删除记录"
                              Command="{Binding DeleteBillCommand}" />
                    <Separator />
                    <MenuItem Header="合并记录"
                              Command="{Binding MergeBillCommand}" />
                </ContextMenu>
            </DataGrid.ContextMenu>

            <DataGrid.Columns>
                <DataGridTextColumn Header="日期时间"
                                    Binding="{Binding DateTimeFormatted}"
                                    Width="*" />
                <DataGridTextColumn Header="交易名称"
                                    Binding="{Binding ItemType}"
                                    Width="*" />
                <DataGridTextColumn Header="对方账户"
                                    Binding="{Binding TargetUser}"
                                    Width="*" />
                <DataGridTextColumn Header="金额"
                                    Binding="{Binding MoneyStr}"
                                    Width="Auto" />
                <DataGridTextColumn Header="支付方式"
                                    Binding="{Binding Method}"
                                    Width="Auto" />
                <DataGridTextColumn Header="状态"
                                    Binding="{Binding StatusStr}"
                                    Width="Auto" />
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>

</UserControl>
